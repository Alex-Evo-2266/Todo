generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TodoList {
  id        String   @id @default(uuid())
  title     String
  ownerId   String   // user id from auth service
  createdAt DateTime @default(now())

  todos     Todo[]
  access    TodoListAccess[]
}

model TodoListAccess {
  id         String   @id @default(uuid())
  todoListId String
  userId     String   // user id from auth service

  todoList  TodoList @relation(fields: [todoListId], references: [id], onDelete: Cascade)

  @@unique([todoListId, userId])
}

model Todo {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime? 

  parentId   String?
  parent   Todo?  @relation("TodoChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children Todo[] @relation("TodoChildren")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  runk        String  @default("0")
  contVersion Int     @default(0)
  posVersion  Int     @default(0)
  status      String?
  completed   Boolean  @default(false)

  todoListId  String
  todoList    TodoList @relation(fields: [todoListId], references: [id], onDelete: Cascade)

  comments    Comment[]

  @@index([todoListId, parentId, runk])
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  authorId  String   // user id from auth service
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  todoId    String
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)
}
